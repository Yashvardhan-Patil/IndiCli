# Render frontend environment example for IndiCli.
# Vite reads VITE_* at build time, so rebuild after changing these.

VITE_API_BASE_URL=https://your-backend-service.onrender.com
VITE_API_TIMEOUT_MS=30000
VITE_ML_API_TIMEOUT_MS=120000
VITE_CESIUM_TOKEN=replace-with-your-cesium-ion-token
VITE_CESIUM_BASEMAP=OpenStreetMap
VITE_CESIUM_TERRAIN=CesiumWorldTerrain
VITE_APP_NAME=IndiCli
VITE_APP_VERSION=1.0.0
