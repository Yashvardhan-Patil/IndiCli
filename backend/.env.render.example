# Render backend environment example for IndiCli.
# Set these in Render Dashboard, do not commit real secrets.

APP_NAME=IndiCli
APP_ENV=production
APP_HOST=0.0.0.0
DEBUG=false
LOG_LEVEL=INFO

# Render provides PORT automatically. The start command should use:
# uvicorn app.main:app --host 0.0.0.0 --port $PORT

# Replace with your deployed frontend URL.
ALLOWED_ORIGINS=https://your-frontend-service.onrender.com

# Prefer Render PostgreSQL's managed DATABASE_URL.
# If your DB uses postgres://, convert to postgresql+asyncpg:// for DATABASE_URL.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_SYNC_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Put the CSV here by committing it, mounting a Render disk, or downloading it
# during build/startup from object storage.
MASTER_CSV_PATH=./data/master_climate_dataset.csv.gz
NETCDF_DIR=./data/netcdf
PROCESSED_DATA_DIR=./data
RAW_IMD_DIR=./data/raw/IMD
RAW_INSAT_DIR=./data/raw/INSAT

MODELS_DIR=./models
MODEL_SAVE_DIR=./models
LSTM_MODEL_PATH=./models/lstm_model.keras
XGBOOST_MODEL_PATH=./models/xgb_rainfall.pkl

UPLOAD_DIR=./uploads
CACHE_DIR=./cache
LOG_DIR=./logs

FORECAST_HORIZON_DAYS=30
LSTM_LOOKBACK_DAYS=60
XGBOOST_N_ESTIMATORS=200
ENSEMBLE_WEIGHTS_XGBOOST=0.55
ENSEMBLE_WEIGHTS_LSTM=0.45
